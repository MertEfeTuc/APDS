@model List<APDS.Models.Activity>

@{
    ViewData["Title"] = "Faaliyetlerim";
    var years = Model
        .Where(a => a.Status == APDS.Models.ActivityStatus.APPROVED)
        .Select(a => a.ActivityDate.Year)
        .Distinct()
        .OrderByDescending(y => y)
        .ToList();

    int selectedYear = Context.Request.Query.ContainsKey("year")
        ? int.Parse(Context.Request.Query["year"])
        : DateTime.Now.Year;

    var totalScore = Model
        .Where(a => a.Status == APDS.Models.ActivityStatus.APPROVED
                 && a.ActivityDate.Year == selectedYear)
        .Sum(a => a.ActivityType?.Score ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Faaliyetlerim</h2>
    <a asp-controller="Activity" asp-action="Create" class="btn btn-primary">+ Yeni Faaliyet</a>
</div>


<div class="d-flex align-items-center gap-3 mb-4">
    <form method="get" class="d-flex align-items-center gap-2 mb-0">
        <label class="form-label mb-0 fw-bold">Yıl:</label>
        <select name="year" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
            @foreach (var year in years)
            {       
                if (year == selectedYear)
                {
                    <option value="@year" selected>@year</option>
                }
                else
                {
                    <option value="@year">@year</option>
                }
            }
        </select>
    </form>
    <span class="badge bg-primary fs-6">@selectedYear Toplam Puan: @totalScore</span>
</div>

@if (!Model.Any())
{
    <p class="text-muted">Henüz hiç faaliyet eklemediniz.</p>
}
else
{
    @* Sıralama bilgisi *@
@if (ViewBag.DeptRank != null)
{
    <div class="d-flex gap-3 mb-4">
        <span class="badge bg-secondary fs-6">
            @ViewBag.DeptName: @ViewBag.DeptRank. / @ViewBag.DeptTotal kişi
        </span>
        @if (ViewBag.FacultyRank != null)
        {
            <span class="badge bg-dark fs-6">
                @ViewBag.FacultyName: @ViewBag.FacultyRank. / @ViewBag.FacultyTotal kişi
            </span>
        }
    </div>
}
    var sortedActivities = Model
        .OrderByDescending(a => a.Status == APDS.Models.ActivityStatus.UNDER_REVIEW)
        .ToList();
     <table class="table table-hover">
        <thead>
            <tr>
                <th>Başlık</th>
                <th>Kategori</th>
                <th>Tür</th>
                <th>Yıl</th>
                <th>Durum</th>
                <th>Puan</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in sortedActivities)
            {
                <tr style="cursor: pointer;" onclick="location.href='@Url.Action("Details", "Activity", new { id = activity.Id })'">
                    <td>@activity.Title</td>
                    <td>@activity.ActivityType.Category</td>
                    <td>@activity.ActivityType.Name</td>
                    <td>@activity.ActivityDate</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(activity.Status)">
                            @activity.Status
                        </span>
                    </td>
                    <td>
                        @if (activity.Status == APDS.Models.ActivityStatus.APPROVED)
                        {
                            <span class="fw-bold text-success">@(activity.ActivityType?.Score ?? 0)</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    string GetStatusBadgeClass(APDS.Models.ActivityStatus status)
    {
        return status switch
        {
            APDS.Models.ActivityStatus.DRAFT => "bg-secondary",
            APDS.Models.ActivityStatus.SUBMITTED => "bg-info",
            APDS.Models.ActivityStatus.UNDER_REVIEW => "bg-warning text-dark",
            APDS.Models.ActivityStatus.APPROVED => "bg-success",
            APDS.Models.ActivityStatus.REJECTED => "bg-danger",
            APDS.Models.ActivityStatus.REVISION_REQUESTED => "bg-warning text-dark",
            APDS.Models.ActivityStatus.RESUBMITTED => "bg-info",
            _ => "bg-secondary"
        };
    }
}