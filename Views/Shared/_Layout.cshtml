<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APDS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/APDS.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm border-bottom box-shadow mb-3 app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">APDS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item d-flex align-items-center">
                            <button id="darkModeToggle" class="btn btn-outline-secondary btn-sm" type="button">
                                🌙
                            </button>
                        </li>
                        @if (User.IsInRole("Akademisyen"))
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Activity" asp-action="Performance">Performansım</a>
    </li>
            }
                    @if (User.IsInRole("Akademisyen") || User.IsInRole("Reviewer") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Comparison" asp-action="DepartmentFacultyComparison">Bölüm/Fakülte Karşılaştırması</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="ActivityTypeReference" asp-action="Index">Faaliyet Türleri</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Leaderboard" asp-action="Index">Sıralama</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="News" asp-action="Index">Haberler</a>
                        </li>
                    }
                    @if (User.IsInRole("Reviewer"))
                    {
                        
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="ReviewerStatistics">Reviewer İstatistikleri</a>
                        </li>
                    }
                    @if (User.IsInRole("Akademisyen"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Calendar" asp-action="Index">Takvim</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Activity" asp-action="Performance">Performansım</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Activity" asp-action="ImportFromPdf">PDF'den İçe Aktar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Profile" asp-action="Index">Profilim</a>
                        </li>
                        
                    }   
                    <a class="nav-link" asp-controller="Security" asp-action="Index">Güvenlik Ayarları</a>
                        @await Component.InvokeAsync("NotificationDropdown")
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                <button id="exitButton" class="btn btn-outline-primary btn-sm" type="submit">
                                    Exit
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - APDS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
