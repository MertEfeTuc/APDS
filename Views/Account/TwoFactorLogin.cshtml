@* Hedef konum: Views/Account/TwoFactorLogin.cshtml *@
@model APDS.Models.TwoFactorLoginViewModel

@{
    ViewData["Title"] = "Doğrulama Kodu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-3 text-center">İki Faktörlü Doğrulama</h2>
        <p class="text-muted text-center mb-4">Authenticator uygulamandaki 6 haneli kodu gir.</p>

        <form asp-controller="Account" asp-action="TwoFactorLogin" method="post">
            <input type="hidden" asp-for="RememberMe" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" autocomplete="one-time-code" autofocus />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMachine" class="form-check-input" />
                <label asp-for="RememberMachine" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-dark w-100">Doğrula</button>
        </form>

        <p class="text-center mt-3">
            <a asp-controller="Account" asp-action="RecoveryCodeLogin">Kurtarma kodu ile giriş yap</a>
        </p>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
