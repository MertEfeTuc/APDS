@model List<APDS.Models.Admin.AdminUserViewModel>

@{
    ViewData["Title"] = "Kullanıcılar";
}
<a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
    ← Panele Dön
</a>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Kullanıcılar</h2>
    <a asp-action="CreateUser" class="btn btn-primary">+ Yeni Kullanıcı</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Kullanıcı Adı</th>
            <th>E-posta</th>
            <th>Rol(ler)</th>
            <th>Düzenle</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>
                @if (!user.Roles.Contains("Admin"))
                {
                    <td>
                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                    </td>
                }
                else
                {
                    <td></td>
                }
            </tr>
        }
    </tbody>
</table>


