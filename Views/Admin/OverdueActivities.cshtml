@model List<APDS.Models.Activity>

@{
    ViewData["Title"] = "Geciken Faaliyetler";
}

<h2>Geciken Faaliyetler (7+ gün)</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-success">Şu anda gecikmiş faaliyet yok.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Başlık</th>
                <th>Akademisyen</th>
                <th>Tür</th>
                <th>Durum</th>
                <th>Kaç Gündür Bekliyor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                var days = (int)(DateTime.UtcNow - activity.LastStatusChangeDate).TotalDays;
                <tr>
                    <td>@activity.Title</td>
                    <td>@activity.Academician?.UserName</td>
                    <td>@activity.ActivityType?.Name</td>
                    <td>@activity.Status</td>
                    <td><span class="badge bg-danger">@days gün</span></td>
                </tr>
            }
        </tbody>
    </table>
}