@model List<ReviewerAssignment>

@{
    ViewData["Title"] = "Reviewer Atamaları";
}
<a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">
    ← Panele Dön
</a>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reviewer Atamaları</h2>
    <a asp-action="CreateAssignment" class="btn btn-primary">+ Yeni Atama</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">Henüz hiç atama yapılmamış.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Akademisyen</th>
                <th>Reviewer</th>
                <th>Atama Tarihi</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Academician.UserName</td>
                    <td>@a.Reviewer.UserName</td>
                    <td>@a.AssignedDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="EditAssignment" asp-route-id="@a.Id" class="btn btn-sm btn-warning">Düzenle</a>
                        <form asp-action="DeleteAssignment" asp-route-id="@a.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Bu atamayı silmek istediğinize emin misiniz?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}